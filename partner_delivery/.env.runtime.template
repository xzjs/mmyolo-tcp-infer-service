# Host directory for model weight files
WEIGHTS_DIR=D:/piping/weights

# Host directory for input files (images/videos)
LOCAL_INPUT_DIR=D:/piping/input

# Host directory for output jsonl/results
OUTPUT_DIR_HOST=D:/piping/output

# Windows path prefix -> container path mapping
# Request path example: D:\piping\input\demo.jpg
# Container path becomes: /data/local_input/demo.jpg
PATH_MAPPINGS=D:/piping/input=/data/local_input
